{
  "name": "openstock-alerts-desktop",
  "description": "Primary OpenStock Electron desktop app; the Web and CLI lanes are retained separately in the repository root.",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "main.mjs",
  "scripts": {
    "dev": "electron .",
    "check:boundaries": "node ../scripts/desktop/check-desktop-boundaries.mjs",
    "dist:win:check-env": "node ../scripts/desktop/run-desktop-windows-build.mjs --check dist:win",
    "dist:win": "node ../scripts/desktop/run-desktop-windows-build.mjs dist:win",
    "dist:win:f": "node ../scripts/desktop/run-desktop-windows-build.mjs dist:win:f",
    "dist:win:f:zip": "node ../scripts/desktop/run-desktop-windows-build.mjs dist:win:f:zip",
    "dist:win:zip:check-env": "node ../scripts/desktop/run-desktop-windows-build.mjs --check dist:win:zip",
    "dist:win:zip": "node ../scripts/desktop/run-desktop-windows-build.mjs dist:win:zip",
    "dist:win:zip:toF": "npm run dist:win:zip && node ./copy-artifacts-to-f.mjs"
  },
  "dependencies": {
    "nodemailer": "^7.0.6"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.openstock.alerts",
    "productName": "OpenStock Alerts",
    "asar": true,
    "files": [
      "**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    }
  }
}
